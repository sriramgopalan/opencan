# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=
NEXT_PUBLIC_APP_URL=

# ── Database (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=

# ── Security ──────────────────────────────────────────────────────────
# Random 32-byte hex string for HMAC IP hashing (guest vote dedup privacy)
# Generate: openssl rand -hex 32
# DEPLOYMENT REQUIREMENT: set this to a unique value in each environment
IP_HASH_SECRET=

# ── Object Storage (MinIO / S3-compatible) ───────────────────────────
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_USE_SSL=

# ── Auth ─────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Playwright (E2E) ─────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=
