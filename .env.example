# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=

# ── Database (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=

# ── Auth ─────────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# Full public URL of your deployment (required in production)
AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=

# ── Security ─────────────────────────────────────────────────────────
# HMAC key for hashing client IPs in guest vote dedup (raw IPs never stored).
# Generate: openssl rand -hex 32
# Must be unique per deployment — the default is insecure.
IP_HASH_SECRET=

# ── Webhooks ─────────────────────────────────────────────────────────
# Maximum number of registered webhook endpoints (default: 10)
# WEBHOOK_MAX=10

# ── Embeddable Widget ────────────────────────────────────────────────
# HS256 secret for widget JWT auto-login. Must be ≥ 32 characters.
# If not set, data-token on the widget script tag is ignored (embed loads as guest).
# Generate: openssl rand -hex 32
# WIDGET_JWT_SECRET=

# Space-separated origins allowed to frame /embed/* pages.
# Example: https://app.example.com https://staging.example.com
# If not set, framing is blocked (frame-ancestors 'none').
# WIDGET_ALLOWED_ORIGINS=

# ── Object Storage (MinIO / S3-compatible) ───────────────────────────
# MinIO is provisioned in docker-compose for future file upload support.
# These variables are not yet required by the application.
MINIO_ENDPOINT=
MINIO_PORT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_USE_SSL=

# ── Playwright (E2E) ─────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=
